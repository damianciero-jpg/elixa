# Firebase client configuration for local Expo runs.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Backend proxy URL used by the app.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional Playwright test credentials.
# Use a dedicated Firebase Authentication test user. Do not put real user secrets here.
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=

# Optional signup test account. If omitted, the signup test only checks validation.
PLAYWRIGHT_SIGNUP_EMAIL=
PLAYWRIGHT_SIGNUP_PASSWORD=
