// storage.rules
//
// Deploy with: firebase deploy --only storage
//
// Future-self media uploads (voice notes, images) are stored under:
//   future_self/{uid}/{filename}
//
// Only the owner can read or write their own media.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Future-self media
    match /future_self/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
